# Variables de entorno requeridas para Dulce Sabor
# Copia este archivo como .env y rellena los valores

# Cadena de conexión a MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# API Key de Google Gemini (para el chatbot)
GEMINI_API_KEY=tu_api_key_aqui

# Puerto del servidor (Railway lo asigna automáticamente)
# PORT=5000
